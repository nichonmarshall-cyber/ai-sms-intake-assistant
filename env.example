# ─────────────────────────────────────────────────────
# Business Identity (drives AI prompt + greeting)
# ─────────────────────────────────────────────────────
BUSINESS_NAME= #1 mechancic shop
BUSINESS_TYPE=auto repair         # e.g. "auto repair", "plumbing", "landscaping"

# ─────────────────────────────────────────────────────
# Business Hours (24-hour format)
# ─────────────────────────────────────────────────────
BUSINESS_OPEN_HOUR=8
BUSINESS_CLOSE_HOUR=17
# Workdays: 0=Monday … 6=Sunday (comma-separated)
BUSINESS_WORKDAYS=0,1,2,3,4
BUSINESS_TIMEZONE=America/Chicago

# ─────────────────────────────────────────────────────
# Twilio
# ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─────────────────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────
# Google Sheets  (leave blank to disable — leads print to terminal)
# ─────────────────────────────────────────────────────
# TODO: Set GOOGLE_SERVICE_ACCOUNT_JSON to the path of your downloaded
#       service account key file, e.g. credentials/service_account.json
#       Then share your Google Sheet with the service account email.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ID=
CLIENT_SHEET_NAME=Leads
INTERNAL_SHEET_NAME=Internal

# ─────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────
# Set to "production" to enable Twilio webhook signature validation
FLASK_ENV=development
MAX_TURNS=15
MAX_HISTORY=12   # Max messages kept in conversation history sent to OpenAI
PORT=5000
